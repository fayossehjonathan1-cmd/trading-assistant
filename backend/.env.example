# === IA (Anthropic) — https://console.anthropic.com/settings/keys ===
ANTHROPIC_API_KEY=
# Modèle par défaut (claude-opus-4-8). Alternatives moins chères: claude-sonnet-5, claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-8

# === Données de marché — https://twelvedata.com (plan gratuit: 800 crédits/jour) ===
TWELVEDATA_API_KEY=

# === Actualités financières — https://www.marketaux.com (plan gratuit) ===
MARKETAUX_API_TOKEN=

# === Notifications Telegram — créer un bot via @BotFather, chat_id via @userinfobot ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Supabase — https://supabase.com/dashboard > Project Settings > API ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === Moteur ===
# 5 min par défaut. Attention: 3 actifs x 5 min = 864 crédits Twelve Data/jour (>800 gratuit).
# Passer à 10 pour rester dans le quota gratuit.
ANALYSIS_INTERVAL_MINUTES=5
# Délai minimal entre deux signaux sur un même actif (limite le coût API Claude)
SIGNAL_COOLDOWN_MINUTES=60
# === Stratégie validée par backtest 6 mois (sweep2.py / sweep3.py) ===
# Bougies 1h, cassure Donchian 10, signaux uniquement en régime tendance.
# TRADE_REGIMES accepte une liste (ex: tendance,range) ou "tous".
CANDLE_INTERVAL=1h
TRADE_REGIMES=tendance
DONCHIAN_PERIOD=10
NEWS_LOOKBACK_HOURS=4
MAX_CONSECUTIVE_LOSSES=3

# Forcer le mode démo complet (aucune clé requise)
MOCK_MODE=false

# Origine(s) autorisée(s) pour le frontend (ex: https://mon-app.vercel.app)
CORS_ORIGINS=*
